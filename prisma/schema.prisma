generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int         @id @default(autoincrement())
  partNo      String      @unique
  description String
  costPrice   Float
  isImportant Boolean     @default(false)
  category    String?
  pdfFile     String?
  quoteItems  QuoteItem[]
  createdAt   DateTime    @default(now())
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  company      String
  passwordHash String
  tier         String   @default("PENDING")
  quotes       Quote[]
  createdAt    DateTime @default(now())
}

model PriceRule {
  tier       String @id
  multiplier Float
}

model Quote {
  id        Int         @id @default(autoincrement())
  user      User        @relation(fields: [userId], references: [id])
  userId    Int
  status    String      @default("DRAFT")
  note      String?
  items     QuoteItem[]
  createdAt DateTime    @default(now())
}

model QuoteItem {
  id        Int     @id @default(autoincrement())
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId   Int
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  quantity  Int
  unitPrice Float
}
